# ================================================
# BERRY SOLUTIONS - SCHOOL MANAGEMENT SYSTEM
# Environment Variables Configuration
# ================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --------------------------------------------
# SERVER CONFIGURATION
# --------------------------------------------
PORT=5000
NODE_ENV=development
API_VERSION=v1

# --------------------------------------------
# MONGODB CONFIGURATION
# --------------------------------------------
MONGODB_URI=mongodb://localhost:27017/berry_school_db
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/berry_school_db?retryWrites=true&w=majority

# --------------------------------------------
# JWT AUTHENTICATION
# --------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# --------------------------------------------
# OPENAI CONFIGURATION (for AI Features)
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# --------------------------------------------
# HUGGING FACE (Alternative AI)
# --------------------------------------------
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key

# --------------------------------------------
# WHATSAPP CONFIGURATION
# --------------------------------------------
WHATSAPP_SESSION_PATH=./whatsapp-session
WHATSAPP_CLIENT_ID=berry-school-client
WHATSAPP_SIMULATION=true

# --------------------------------------------
# CORS CONFIGURATION
# --------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --------------------------------------------
# SCHOOL SETTINGS
# --------------------------------------------
SCHOOL_NAME=Berry Solutions School
SCHOOL_LATE_THRESHOLD_HOUR=8
SCHOOL_LATE_THRESHOLD_MINUTE=0

# --------------------------------------------
# RATE LIMITING
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------
# LOGGING
# --------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log
